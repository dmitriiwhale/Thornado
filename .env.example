# Copy to .env: `cp .env.example .env` — docker compose reads .env for ${VAR} substitution.

# --- TimescaleDB (docker compose service `postgres`) ---
POSTGRES_USER=thornado
POSTGRES_PASSWORD=thornado
POSTGRES_DB=thornado
# Host port mapped to the container (default 5433 if 5432 is already used by local Postgres).
POSTGRES_PORT=5433

# --- Gateway: run on HOST (go run / IDE) while Postgres is in Docker ---
# Port must match POSTGRES_PORT above.
DATABASE_URL=postgres://thornado:thornado@127.0.0.1:5433/thornado?sslmode=disable

# --- Gateway in Docker gets DATABASE_URL from docker-compose.yml (postgres hostname). ---
# Override only if you customize user/password/db above.

JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SIWE_DOMAIN=localhost:5173
GATEWAY_PORT=3001
FRONTEND_PORT=5173

# --- Rust execution gateway ---
# Go gateway proxies /api/execution/* to this internal service.
EXECUTION_SERVICE_URL=http://127.0.0.1:3003
EXECUTION_PORT=3003
EXECUTION_NETWORK=test
# Optional explicit upstream overrides for nado-rust-sdk:
# EXECUTION_NADO_GATEWAY_URL=https://gateway.nado.xyz/v1
# EXECUTION_NADO_TRIGGER_URL=https://trigger.nado.xyz/v1

# --- Rust portfolio gateway ---
# Go gateway proxies /api/portfolio/* to this internal service.
PORTFOLIO_SERVICE_URL=http://127.0.0.1:3006
PORTFOLIO_PORT=3006
PORTFOLIO_NETWORK=test
# Optional explicit upstream overrides for nado-rust-sdk:
# PORTFOLIO_NADO_GATEWAY_URL=https://gateway.nado.xyz/v1
# Optional override. Default for portfolio stream follows gateway subscriptions endpoint for selected network.
# Example testnet override:
# PORTFOLIO_NADO_WS_URL=wss://gateway.test.nado.xyz/v1/subscribe
# PORTFOLIO_NADO_ARCHIVE_URL=https://archive.nado.xyz/v1
PORTFOLIO_DEFAULT_SUBACCOUNT=default
PORTFOLIO_POLL_MS=5000
PORTFOLIO_EVENT_REFRESH_DEBOUNCE_MS=750

# Optional: override the Vite proxy target for local or containerized frontend runs.
# Local default is http://127.0.0.1:3001, docker-compose sets it to http://gateway:3001.
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
# Optional: terminal markets data service override.
# VITE_MARKETS_HTTP_BASE=http://127.0.0.1:3005

# --- Rust orderbook gateway ---
# Defaults: bind 0.0.0.0:3002, depth 20, and prewarm all symbols.
# ORDERBOOK_BIND_ADDR=0.0.0.0:3002
# ORDERBOOK_NETWORK=test
# ORDERBOOK_DEPTH=20
# ORDERBOOK_PREWARM_ALL=true
# Optional: prewarm only specific symbols (comma-separated) when ORDERBOOK_PREWARM_ALL=false.
# ORDERBOOK_SYMBOLS=BTC-PERP,ETH-PERP
# Optional explicit upstream subscriptions URL:
# ORDERBOOK_NADO_WS_URL=wss://gateway.test.nado.xyz/v1/subscribe

# --- Rust markets gateway (aggregated symbols + tickers + contracts) ---
MARKETS_PORT=3005
MARKETS_NETWORK=test
# Optional: ask indexer for edge markets
# MARKETS_EDGE=true
MARKETS_SYMBOLS_REFRESH_MS=300000
MARKETS_TICKERS_POLL_MS=1000
MARKETS_CONTRACTS_POLL_MS=3000
MARKETS_STALE_AFTER_MS=20000
# Funding interval length used to annualize `funding_rate` into `ann_funding` (%).
# Hourly mode (1h).
MARKETS_FUNDING_INTERVAL_HOURS=1

# --- Rust chart gateway + timeseries-db storage ---
CHART_PORT=3004
CHART_NETWORK=test
# For host run, defaults to DATABASE_URL if CHART_DATABASE_URL is not set.
# CHART_DATABASE_URL=postgres://thornado:thornado@127.0.0.1:5433/thornado?sslmode=disable
# Optional upstream overrides:
# CHART_NADO_WS_URL=wss://gateway.test.nado.xyz/v1/subscribe
# CHART_NADO_ARCHIVE_URL=https://archive.test.nado.xyz/v1
CHART_DEFAULT_GRANULARITY=60
CHART_SUPPORTED_GRANULARITIES=60,300,900,3600,7200,14400,86400
CHART_HISTORY_LIMIT=500
CHART_CACHE_CAPACITY=1500
CHART_PREWARM_ALL=false
# CHART_PREWARM_SYMBOLS=BTC-PERP,ETH-PERP
CHART_PREWARM_GRANULARITIES=60
